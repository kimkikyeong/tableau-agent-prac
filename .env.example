TABLEAU_VDS_ENDPOINT=https://<your-tableau-server>/
TABLEAU_PAT_NAME=<your-pat-name>
TABLEAU_PAT_SECRET=<your-pat-secret>
TABLEAU_SITE_ID=<your-site-content-url>   # 기본 사이트는 빈 문자열
TABLEAU_TIMEOUT=30

# 공식 Tableau MCP 서버 기동 명령어 (설치 방법에 따라 조정)
# 예시 1 - uvx:  TABLEAU_OFFICIAL_MCP_CMD=uvx / TABLEAU_OFFICIAL_MCP_ARGS=mcp-server-tableau
# 예시 2 - npx:  TABLEAU_OFFICIAL_MCP_CMD=npx / TABLEAU_OFFICIAL_MCP_ARGS=-y @tableau/mcp-server
TABLEAU_OFFICIAL_MCP_CMD=uvx
TABLEAU_OFFICIAL_MCP_ARGS=mcp-server-tableau

# 에이전트 LLM 모델 (기본값: claude-sonnet-4-6)
AGENT_MODEL=claude-sonnet-4-6

# Anthropic API Key
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# Gemini API Key (STEP 01 fetch_step01.py의 LLM 비즈니스 글로서리 자동 생성용)
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-3.5-flash
